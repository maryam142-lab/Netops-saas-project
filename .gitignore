# Root gitignore for the NetOps monorepo

# Node / JS
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Environment & secrets
.env
.env.*
!.env.example
.env
server/.env
client/.env

# Build outputs
dist/
build/
out/

# Coverage
coverage/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Docker
**/docker/*.env

